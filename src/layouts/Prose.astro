---
import "../styles/global.css";
---

<div class="prose">
  <slot />
</div>

<style>
  :global(.prose > * + p) {
    margin-block-start: var(--space-s);
  }

  :global(.prose > * + h2) {
    margin-block-start: var(--space-2xl);
  }

  :global(.prose > * + h3) {
    margin-block-start: var(--space-l);
  }

  :global(.prose > * + h4) {
    margin-block-start: var(--space-m);
  }

  :global(.prose > * + h5) {
    margin-block-start: var(--space-s);
  }

  :global(.prose > * + h6) {
    margin-block-start: var(--space-s);
  }
</style>
