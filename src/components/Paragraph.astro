---
import "../styles/global.css";
interface Props {
  intro?: boolean;
}
const { intro } = Astro.props;
---

<p class:list={[{ intro: intro }]}><slot /></p>

<style>
  p {
    font-size: var(--step-0);
    max-width: 50ch;
  }
  .intro {
    font-size: var(--step-1);
    color: var(--color-content-subtle);
    max-width: 40ch;
  }
</style>
