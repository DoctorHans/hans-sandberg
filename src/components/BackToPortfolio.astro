---
import Icon from "./Icon.astro";
---

<a href="/portfolio"
  ><Icon name={"arrowLeft"} class="icon" />Back to portfolio</a
>

<style>
  @keyframes left-right-wiggle {
    0% {
      transform: translateX(0%);
    }
    50% {
      transform: translateX(-20%);
    }
    100% {
      transform: translateX(0%);
    }
  }

  .icon {
    color: var(--color-accent);
    width: var(--step-0);
    height: var(--step-0);
    transition: var(--motion-exit-small);
    transition-property: color;
  }

  a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3xs);
    color: var(--color-content-quiet);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    padding-block-start: var(--space-s);
    transition: var(--motion-exit-small);
    transition-property: color;

    &:hover {
      color: var(--color-accent);
      transition: var(--motion-enter-small);
      transition-property: color;

      .icon {
        animation: left-right-wiggle var(--motion-duration-slow)
          var(--motion-easing-enter-and-exit) both;
      }
    }
  }
</style>
