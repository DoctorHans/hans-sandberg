---
import "../styles/global.css";
interface Props {
  level: "1" | "2" | "3" | "4" | "5" | "6";
  step?: string;
  id?: string;
}
type H = "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
const { level, step, id } = Astro.props;
const H = `h${level}` as H;
---

<H class:list={[{ wrapper: step }]} id={id}>
  {step && <span class="step">Step {step}.</span>}
  <slot />
</H>

<style lang="scss">
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    line-height: 1.2;
    max-width: 25ch;
    color: var(--color-content-loud);
    scroll-margin-top: calc(var(--space-2xl) + 1.5rem);
  }

  h1 {
    font-size: var(--step-4);
    margin-block-start: var(--space-2xl);
  }

  h2 {
    font-size: var(--step-3);
  }

  h3 {
    font-size: var(--step-2);
  }

  h4 {
    font-size: var(--step-1);
  }

  h5 {
    font-size: var(--step--1);
  }

  h6 {
    font-size: var(--step--2);
  }

  .step {
    color: var(--color-content-subtle);
  }

  .wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }
</style>
