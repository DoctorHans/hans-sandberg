---
import type { HTMLTag, Polymorphic } from "astro/types";
import type { IconName } from "../types/IconName";
import "../styles/global.css";
import Icon from "./Icon.astro";

type Props<Tag extends HTMLTag> = Polymorphic<{
  as: Tag;
  icon?: IconName;
}>;

const { as: Tag = "button", icon = "download", ...props } = Astro.props;
---

<Tag {...props}><slot /><Icon name={icon} class="icon" /></Tag>

<style lang="scss">
  button,
  a {
    font-size: var(--step--1);
    font-weight: var(--font-weight-semibold);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-m);
    border: var(--border-size-regular) solid var(--color-border-regular);
    color: var(--color-content-regular);
    background-color: var(--color-background);
    border-radius: var(--border-radius-regular);
    cursor: pointer;
    text-align: left;
    transition: border-color var(--motion-duration-regular);

    &:hover {
      border-color: var(--color-border-loud);
      color: var(--color-content-loud);

      .icon {
        color: var(--color-content-loud);
      }
    }

    .icon {
      height: var(--step-0);
      width: var(--step-0);
      transition: color var(--motion-duration-regular);
    }
  }

  a {
    text-decoration: none;
  }
</style>
