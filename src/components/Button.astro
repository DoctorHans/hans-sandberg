---
import type { HTMLTag, Polymorphic } from "astro/types";
import type { IconName } from "./Icon.astro";

import Icon from "./Icon.astro";

type Props<Tag extends HTMLTag> = Polymorphic<{
  as: Tag;
  icon?: IconName;
}>;

const { as: Tag = "button", icon = "download", ...props } = Astro.props;
---

<Tag {...props}><slot /><Icon name={icon} class="icon" /></Tag>

<style lang="scss">
  button,
  a {
    font-weight: var(--font-weight-semibold);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-m);
    border: var(--border-quiet);
    color: var(--color-content-regular);
    background-color: var(--color-background);
    border-radius: var(--border-radius-regular);
    cursor: pointer;
    text-align: left;
    transition: var(--motion-exit-small);
    transition-property: color, transform;

    .icon {
      height: var(--step-0);
      width: var(--step-0);
      color: var(--color-accent);
    }

    &:hover {
      color: var(--color-accent);
      transform: scale(var(--scale-up-small));
      transition: var(--motion-enter-small);
      transition-property: color, transform;
    }

    &:active {
      transform: scale(1);
      transition: transform var(--motion-exit-small);
    }
  }

  a {
    text-decoration: none;
  }
</style>
