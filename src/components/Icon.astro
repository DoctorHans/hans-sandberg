---
import type { HTMLAttributes } from "astro/types";
import type { IconName } from "../types/IconName";
import "../styles/global.css";
interface Props extends HTMLAttributes<"svg"> {
    name: IconName;
}

const { name = "download", ...rest } = Astro.props;

const iconPaths = {
    arrowRight: `<path d="M5 12h14M12 5l7 7-7 7"></path>`,
    chevronRight: `<polyline points="9 18 15 12 9 6"></polyline>`,
    compose: `<path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>`,
    copy: `<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>`,
    download: `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
          points="7 10 12 15 17 10"></polyline><line
          x1="12"
          y1="15"
          x2="12"
          y2="3"></line>`,
    linkedin: `<path
          d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
        ></path><rect x="2" y="9" width="4" height="12"></rect><circle
          cx="4"
          cy="4"
          r="2"></circle>`,
};

const iconPath = iconPaths[name];
---

<svg
    {...rest}
    width="36"
    height="36"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="2"
    viewBox="0 0 24 24"
    aria-hidden="true"
    set:html={iconPath}
/>
