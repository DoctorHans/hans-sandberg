---
import SkipLink from "./SkipLink.astro";
import Nav from "./Nav.astro";
import Logo from "./Logo.astro";
---

<header class="page-wrapper">
  <SkipLink />
  <div class="wrapper">
    <Logo />
    <Nav />
  </div>
</header>

<style>
  .wrapper {
    padding-block: var(--space-s);
    display: flex;
    flex-wrap: wrap;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-s);
  }
</style>
