<span id="greeting-element"></span>

<script>
  const date = new Date();
  const hours = date.getHours();
  function getGreeting(hours: number) {
    if (hours < 5) {
      return "Good evening";
    } else if (hours < 12) {
      return "Good morning";
    } else if (hours < 18) {
      return "Good afternoon";
    } else {
      return "Good evening";
    }
  }
  const greeting = getGreeting(hours);
  const greetingElement = document.getElementById("greeting-element");
  if (greetingElement) {
    greetingElement.textContent = greeting;
  }
</script>
