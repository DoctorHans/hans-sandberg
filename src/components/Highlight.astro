---
import type { HTMLAttributes } from "astro/types";

import type { IconName } from "./Icon.astro";
import Icon from "./Icon.astro";
interface Props extends HTMLAttributes<"div"> {
  title?: string;
  listItem?: boolean;
  blockquote?: boolean;
  icon?: IconName;
}
const {
  title,
  listItem = true,
  blockquote = false,
  icon = "download",
  class: className,
  ...rest
} = Astro.props;
const Wrapper = listItem ? "li" : "div";
const Content = blockquote ? "blockquote" : "div";
const hasTitle = !!title;
---

<Wrapper
  class:list={[
    "wrapper",
    hasTitle ? "wrapper--with-title" : "wrapper--no-title",
    className,
  ]}
  {...rest}
>
  <Icon name={icon} class="icon" />
  {hasTitle && <strong class="title">{title}</strong>}
  <Content class="content">
    <slot />
  </Content>
</Wrapper>

<style>
  .wrapper {
    background: var(--color-background-loud);
    border-radius: var(--border-radius-regular);
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: var(--space-xs);
    align-items: center;
    padding: var(--space-s);
  }

  .wrapper--with-title {
    grid-template-areas:
      "icon title"
      ". content";
  }

  .wrapper--no-title {
    grid-template-areas: "icon content";
  }

  .icon {
    width: 1em;
    height: 1em;
    color: var(--color-accent);
    grid-area: icon;
  }
  .title {
    color: var(--color-content-loud);
    grid-area: title;
  }

  .content {
    grid-area: content;
  }
</style>
