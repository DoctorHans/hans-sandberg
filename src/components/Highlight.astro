---
import type { HTMLAttributes } from "astro/types";

import type { IconName } from "./Icon.astro";
import Icon from "./Icon.astro";
interface Props extends HTMLAttributes<"div"> {
  title: string;
  listItem?: boolean;
  blockquote?: boolean;
  icon?: IconName;
}
const {
  title,
  listItem = true,
  blockquote = false,
  icon = "download",
  class: className,
  ...rest
} = Astro.props;
const Wrapper = listItem ? "li" : "div";
const Content = blockquote ? "blockquote" : "div";
---

<Wrapper class:list={["wrapper", className]} {...rest}>
  <Icon name={icon} class="icon" />
  <strong class="title">{title}</strong>
  <Content class="content"><slot /></Content>
</Wrapper>

<style lang="scss">
  .wrapper {
    background: var(--color-background-loud);
    border-radius: var(--border-radius-regular);
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: var(--space-2xs);
    row-gap: var(--space-3xs);
    align-items: center;
    padding: var(--space-s);
  }

  .icon {
    width: 1em;
    height: 1em;
    color: var(--color-accent);
    grid-column: 1;
    grid-row: 1;
  }
  .title {
    font-size: var(--step--1);
    grid-column: 2;
    grid-row: 1;
  }

  .content {
    grid-column: 2;
    grid-row: 2;
  }
</style>
