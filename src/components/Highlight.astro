---
import "../styles/global.css";
interface Props {
  title: string;
  headingLevel?: "1" | "2" | "3" | "4" | "5" | "6";
}
type Heading = "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
const { title, headingLevel = "3" } = Astro.props;
const Title = `h${headingLevel}` as Heading;
---

<li class="wrapper">
  <Title>{title}</Title>
  <p><slot /></p>
</li>

<style lang="scss">
  .wrapper {
    --flow-space: 0;
    background: var(--color-background-subtle);
    border-radius: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-m);
  }
</style>
