---
import Icon from "./Icon.astro";
---

<a href="#main">Skip to content<Icon name={"arrowDown"} class="icon" /></a>

<style>
  a {
    display: flex;
    align-items: center;
    gap: var(--space-3xs);
    font-size: var(--step--1);
    font-weight: var(--font-weight-semibold);
    position: absolute;
    top: var(--space-xs);
    background-color: var(--color-accent);
    padding-inline: var(--space-s);
    padding-block: var(--space-2xs);
    text-decoration: none;
    color: var(--color-background);
    border-radius: var(--border-radius-round);
    opacity: 0;
    transform: translateY(calc(-100% - var(--space-l)));
    transition:
      transform var(--motion-exit-small),
      opacity var(--motion-exit-small);
    will-change: transform;
    &:focus {
      opacity: 1;
      transform: translateY(0%);
      outline: none;
      transition:
        transform var(--motion-enter-small),
        opacity var(--motion-enter-small);
      will-change: transform;
    }
  }

  .icon {
    color: var(--color-content-inverse);
    width: var(--step--1);
    height: var(--step--1);
  }
</style>
