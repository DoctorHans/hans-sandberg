---
import "../styles/global.css";
import Heading from "./Heading.astro";
import Paragraph from "./Paragraph.astro";

interface Props {
  title: string;
  org: string;
  orgLink: string;
  location: string;
  duration: string;
  dateRange: string;
}

const { title, org, orgLink, location, duration, dateRange } = Astro.props;
---

<article class="wrapper">
  <div class="what">
    <h2 id="title">{title}</h2>
  </div>
  <div class="where">
    <Paragraph color="loud" weight="semibold">
      <a href=`${orgLink}`>{org}</a>
    </Paragraph>
    <Paragraph color="subtle">{location}</Paragraph>
  </div>
  <div class="when">
    <Paragraph color="loud" weight="semibold">{duration}</Paragraph>
    <Paragraph color="subtle">{dateRange}</Paragraph>
  </div>
</article>

<style lang="scss">
  .wrapper {
    --flow-space: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--space-m) var(--space-xl);
    border-block-end: 1px solid var(--color-border-subtle);
    padding-block: var(--space-m);
  }

  #title {
    color: var(--color-content-loud);
    font-size: var(--step-0);
    font-weight: var(--font-weight-semibold);
  }

  .where {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  .when {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  .what {
  }
</style>
