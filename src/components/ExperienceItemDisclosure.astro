---
import "../styles/global.css";
import Icon from "./Icon.astro";
import VisuallyHidden from "./VisuallyHidden.astro";

interface Props {
    label: string;
}

const { label } = Astro.props;
---

<button class="disclosure-button" aria-expanded="false"
    ><span class="visible-label" aria-hidden="true">Details</span
    ><VisuallyHidden class="sr-only">{label}</VisuallyHidden><Icon
        name="chevronRight"
        class="icon-chevron-right"
    />
</button>
<div aria-hidden="true" class="details">
    <div class="details-inner"><slot /></div>
</div>

<style lang="scss">
    .disclosure-button {
        border: none;
        display: flex;
        gap: var(--space-3xs);
        align-items: center;
        color: var(--color-content-subtle);
        cursor: pointer;
        transition: color var(--motion-duration-regular);
        align-self: flex-start;

        &:hover {
            color: var(--color-content-loud);
        }
    }

    .disclosure-button[aria-expanded="true"] {
        .icon-chevron-right {
            transform: rotate(90deg);
        }
    }

    .icon-chevron-right {
        width: var(--step-0);
        height: var(--step-0);
        flex-shrink: 0;
        transition: transform var(--motion-duration-regular);
    }

    .visible-label {
        font-size: var(--step--1);
    }

    @container my-container (min-width: 50ch) {
        .disclosure-button {
            width: var(--step-2);
            height: var(--step-2);
            background-color: var(--color-background-loud);
            border-radius: var(--border-radius-round);
            display: grid;
            place-content: center;

            .icon-chevron-right {
                transform: rotate(90deg);
            }

            &[aria-expanded="true"] {
                .icon-chevron-right {
                    transform: rotate(270deg);
                }
            }
        }

        .visible-label {
            display: none;
        }
    }

    .details {
        display: grid;

        &[aria-hidden="false"] {
            grid-template-rows: 1fr;
            opacity: 1;
            transition:
                opacity var(--motion-duration-extra-slow),
                grid-template-rows var(--motion-duration-fast);
            margin-block-end: var(--space-m);
        }

        &[aria-hidden="true"] {
            grid-template-rows: 0fr;
            opacity: 0;
            transition:
                opacity var(--motion-duration-fast),
                grid-template-rows var(--motion-duration-regular);
        }
    }

    .details-inner {
        overflow: hidden;
    }
</style>

<script>
    const disclosureButtons = document.querySelectorAll(".disclosure-button");

    disclosureButtons.forEach((disclosureButton, idx) => {
        const content: Element | null = disclosureButton.nextElementSibling;
        content?.setAttribute("id", `content-${idx + 1}`);
        disclosureButton.setAttribute("aria-controls", `content-${idx + 1}`);

        function toggleDisclosure() {
            if (disclosureButton.getAttribute("aria-expanded") === "false") {
                disclosureButton.setAttribute("aria-expanded", "true");
                content?.setAttribute("aria-hidden", "false");
            } else {
                disclosureButton.setAttribute("aria-expanded", "false");
                content?.setAttribute("aria-hidden", "true");
            }
        }

        disclosureButton.addEventListener("click", toggleDisclosure);
    });
</script>
