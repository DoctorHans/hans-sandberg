---
interface Props {
  headings: {
    depth: number;
    slug: string;
    text: string;
  }[];
}

const { headings } = Astro.props;
---

<div class="wrapper">
  <h2>Contents</h2>
  <ul>
    {
      headings
        .filter((heading) => heading.depth === 2)
        .map((heading) => (
          <li>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))
    }
  </ul>
</div>

<style>
  .wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    background: var(--color-background-loud);
    padding-inline: var(--space-m);
    padding-block: var(--space-s);
    border-radius: var(--border-radius-regular);
  }
  h2 {
    font-size: var(--step--1);
  }
  ul {
    padding-inline: 0;
    list-style: "";
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }
  a {
    text-decoration: none;
  }
</style>
