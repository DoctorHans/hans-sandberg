---
interface Props {
  headings: {
    depth: number;
    slug: string;
    text: string;
  }[];
}

const { headings } = Astro.props;
---

<h2>On this page</h2>
<ul>
  {
    headings
      .filter((heading) => heading.depth === 2)
      .map((heading) => (
        <li>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))
  }
</ul>
