---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlockLink from "../../components/BlockLink.astro";
import BlockLinkList from "../../layouts/BlockLinkList.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getCollection } from "astro:content";
const title = "Portfolio";
const caseStudies = await getCollection("caseStudies");
---

<BaseLayout pageTitle={title}>
  <div class="grid">
    <PageHeader heading={title}>
      Get a feel for how I tackle design challenges
    </PageHeader>
    <BlockLinkList>
      {
        caseStudies
          .sort((a, b) => a.data.order - b.data.order)
          .map((caseStudy) => (
            <BlockLink
              title={caseStudy.data.title}
              subTitle={caseStudy.data.description}
              url={`/portfolio/${caseStudy.data.slug}`}
            />
          ))
      }
    </BlockLinkList>
  </div>
</BaseLayout>
