---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockLink from "../components/BlockLink.astro";
import BlockLinkCollection from "../components/BlockLinkCollection.astro";
import PageHeader from "../components/PageHeader.astro";
import { Image } from "astro:assets";
import Portrait from "../images/me.jpeg";
---

<BaseLayout pageTitle="Home Page">
  <div class="wrapper-image-header">
    <div class="image-container">
      <Image
        src={Portrait}
        alt="john"
        width="320"
        densities={[2, 3, 4]}
        class="image-portrait"
      />
    </div>
    <PageHeader heading="Hello, I'm Hans" spaceAtTop={false}>
      I’m a designer working on a design system at <a
        href="https://www.pleo.io/">Pleo</a
      > in Copenhagen. Building bridges between design and development is what I
      do best and enjoy most.
    </PageHeader>
  </div>
  <BlockLinkCollection>
    <BlockLink
      title="About"
      subTitle="Get to know me a bit better"
      url="about"
    />
    <BlockLink
      title="Experience"
      subTitle="Learn about where I’ve worked and what I’ve worked on"
      url="experience"
    />
    <BlockLink
      title="Portfolio"
      subTitle="Get a feel for how I tackle design challenges"
      url="portfolio"
    />
    <BlockLink
      title="Contact"
      subTitle="Find out how to get in touch"
      url="contact"
    />
  </BlockLinkCollection>
</BaseLayout>

<style>
  .image-portrait {
    filter: grayscale();
    object-fit: cover;
    object-position: 54% -16px;
  }

  .image-container {
    width: calc(2 * var(--space-3xl));
    height: calc(2 * var(--space-3xl));
    overflow: hidden;
    border-radius: 50%;
    margin-block-start: var(--space-2xl);
  }

  .wrapper-image-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }
</style>
