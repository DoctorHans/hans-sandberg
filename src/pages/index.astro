---
import BaseLayout from "../layouts/BaseLayout.astro";
import meImage from "../images/me.jpeg";
import Heading from "../components/Heading.astro";
import Paragraph from "../components/Paragraph.astro";
import BlockLink from "../components/BlockLink.astro";
import BlockLinkCollection from "../components/BlockLinkCollection.astro";
import PageHeader from "../components/PageHeader.astro";
---

<BaseLayout pageTitle="Home Page">
  <PageHeader title="Hello, I'm Hans">
    I’m a designer working on a design system at <a href="https://www.pleo.io/"
      >Pleo</a
    > in Copenhagen. Building bridges between design and development is what I
    do best and enjoy most.
  </PageHeader>
  <BlockLinkCollection>
    <BlockLink
      title="About"
      subTitle="Get to know me a bit better"
      url="about"
    />
    <BlockLink
      title="Experience"
      subTitle="Learn about where I’ve worked and what I’ve worked on"
      url="experience"
    />
    <BlockLink
      title="Portfolio"
      subTitle="Get a feel for how I tackle design challenges"
      url="portfolio"
    />
    <BlockLink
      title="Contact"
      subTitle="Find out how to get in touch"
      url="contact"
    />
  </BlockLinkCollection>
</BaseLayout>
